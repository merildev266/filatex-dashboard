# ─── Filatex Dashboard — variables d'environnement ───
# Copier en `.env` (ignoré par git) et adapter aux valeurs locales.

# ── Backend Flask (app.py, auth.py) ──
# Secret JWT (obligatoire en prod — sinon fallback "change-me")
JWT_SECRET=change-me-a-random-long-string

# Chemin OneDrive racine utilisé par les generate_*.py (facultatif)
# Par défaut: %USERPROFILE% sous Windows
# USERPROFILE=C:\Users\Meril

# ── Frontend Vite (frontend/.env.local) ──
# URL API du backend Flask (dev: http://localhost:5000)
VITE_API_URL=http://localhost:5000
