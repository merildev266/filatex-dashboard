# ============================================================
# Filatex Dashboard — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================
#
# ── Google Cloud Run deployment notes ────────────────────────
# Variables are split into two categories:
#
#   SECRET MANAGER (sensitive — never set as plain env vars in production):
#     AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, ONEDRIVE_DRIVE_ID
#     → Store with: gcloud secrets create filatex-<name> --data-file=-
#     → Reference in Cloud Run: --set-secrets=VAR=secret-name:latest
#
#   PLAIN ENV VARS (non-sensitive — safe to set via --set-env-vars):
#     All TTL_*, LOG_LEVEL, DATA_BASE_PATH, GUNICORN_*, FLASK_DEBUG
#     → Set in cloudbuild.yaml or deploy.sh --set-env-vars block
#
# ── Local development ─────────────────────────────────────────
# Copy to .env and fill in real values. python-dotenv loads it automatically.
# ============================================================

# ------------------------------------------------------------------
# Azure App Registration (Client Credentials flow)
# Create at: https://portal.azure.com → App registrations
# Required API permissions (Application type, admin consent needed):
#   - Files.Read.All
#   - Files.ReadWrite.All  (for comment write-back)
#   - Sites.Read.All
#
# PRODUCTION: store in Secret Manager as:
#   filatex-azure-tenant-id
#   filatex-azure-client-id
#   filatex-azure-client-secret
# ------------------------------------------------------------------
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret-value-here

# ------------------------------------------------------------------
# OneDrive / SharePoint Drive
# Discover with:
#   GET https://graph.microsoft.com/v1.0/sites?search=filatex  → site.id
#   GET https://graph.microsoft.com/v1.0/sites/{site-id}/drives → drive.id
#
# PRODUCTION: store in Secret Manager as: filatex-onedrive-drive-id
# ------------------------------------------------------------------
ONEDRIVE_DRIVE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Base folder path inside the drive (all relative paths are appended to this)
# PRODUCTION: set via --set-env-vars in deploy.sh / cloudbuild.yaml
DATA_BASE_PATH=Fichiers de DOSSIER DASHBOARD - Data_Dashbords

# ------------------------------------------------------------------
# Cache TTL settings (seconds)
# Default values shown — override as needed per environment.
# PRODUCTION: set via --set-env-vars (non-sensitive)
# ------------------------------------------------------------------
TTL_HFO_SITES=3600
TTL_ENR_SITES=3600
TTL_HFO_PROJECTS=1800
TTL_ENR_PROJECTS=900
TTL_CAPEX=3600
TTL_REPORTING=900
TTL_INVESTMENTS=900

# Default TTL for any key without a specific setting
TTL_DEFAULT=900

# Background refresh: pre-warm keys this many seconds before expiry
REFRESH_AHEAD_SECONDS=120

# How often the background refresh worker checks for expiring keys (seconds)
REFRESH_WORKER_INTERVAL=60

# ------------------------------------------------------------------
# Logging
# PRODUCTION: set via --set-env-vars
# ------------------------------------------------------------------
LOG_LEVEL=INFO

# ------------------------------------------------------------------
# Flask (local dev only — gunicorn ignores FLASK_DEBUG)
# ------------------------------------------------------------------
FLASK_DEBUG=false

# ------------------------------------------------------------------
# Gunicorn (production WSGI server)
# PRODUCTION: set via --set-env-vars
# ------------------------------------------------------------------
GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
