# Filatex Dashboard — Production config
# Copier ce fichier en .env et adapter les valeurs

# Mode : production ou development
FLASK_ENV=production

# Secret JWT (changer obligatoirement en production)
JWT_SECRET=CHANGEZ-MOI-avec-une-chaine-aleatoire-longue

# Port du serveur Flask
PORT=5000

# Host (0.0.0.0 pour accepter les connexions externes)
HOST=0.0.0.0
